                  <g transform="matrix(.26718 0 0 .26718 0 0)">
                    <circle cx="950" cy="950" r="950" fill="#7d2ae7"/>
                    <circle cx="950" cy="950" r="950" fill="url(#canvaR1)"/>
                    <circle cx="950" cy="950" r="950" fill="url(#canvaR2)"/>
                    <circle cx="950" cy="950" r="950" fill="url(#canvaR3)"/>
                    <circle cx="950" cy="950" r="950" fill="url(#canvaR4)"/>
