---
const equipment = [
  { name: 'Камера Canon', type: 'hardware', icon: '📷' },
  { name: 'DJI Mic Mini', type: 'hardware', icon: '🎙️' },
  { name: 'iPhone 15 Pro', type: 'hardware', icon: '📱' },
  { name: 'Canva', type: 'software', icon: 'canva' },
  { name: 'CapCut', type: 'software', icon: 'capcut' },
];
---

<section id="equipment" class="py-20 md:py-32 bg-bg-section">
  <div class="max-w-7xl mx-auto">
    <h2 class="equip-title text-3xl md:text-5xl font-bold text-text-primary text-center mb-4 px-4">
      Наша система та обладнання
    </h2>
    <p class="text-text-muted text-center mb-12 px-4 max-w-2xl mx-auto">
      Ми переносимо нашу відпрацьовану систему на вашу нішу, щоб отримати прогнозований результат, а не випадкові перегляди
    </p>

    <div class="relative group">
      <button
        class="equip-prev absolute left-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-bg-card/80 backdrop-blur border border-deep-violet rounded-full flex items-center justify-center text-violet-300 hover:bg-violet-600 hover:text-white transition-all opacity-0 group-hover:opacity-100 hidden"
        aria-label="Previous"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>

      <div class="equip-track carousel-track flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory px-4 md:px-12 pb-4">
        {equipment.map((item) => (
          <div class="equip-card flex-shrink-0 w-48 md:w-56 snap-center bg-bg-card border border-deep-violet rounded-2xl p-6 text-center transition-all duration-300 hover:border-violet-600 hover:shadow-[0_0_20px_rgba(124,58,237,0.15)]">
            <div class="text-4xl mb-3 flex items-center justify-center">
              {item.icon === 'canva' ? (
                <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" class="text-violet-300">
                  <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 14.55c-.384 1.49-1.505 2.834-3.14 3.51-.655.27-1.352.41-2.064.41-1.13 0-2.146-.36-2.89-.98-.34-.283-.6-.6-.79-.93a2.27 2.27 0 0 1-.293-1.12c0-.513.2-.968.543-1.28.33-.3.753-.44 1.16-.44.66 0 1.17.39 1.39.99.07.2.12.41.18.62.06.22.13.44.24.62.2.33.53.5.99.5.67 0 1.28-.39 1.69-.95.44-.6.66-1.39.66-2.18 0-.8-.24-1.54-.71-2.1-.5-.6-1.24-.94-2.12-.94-.62 0-1.27.17-1.88.44-.68.3-1.26.72-1.75 1.2-.98.98-1.68 2.24-2.13 3.3a.47.47 0 0 1-.6.27.47.47 0 0 1-.3-.56c.27-1.15.77-2.47 1.63-3.67.42-.59.93-1.14 1.54-1.58.65-.47 1.4-.82 2.24-.97.34-.06.68-.09 1.02-.09 1.28 0 2.41.46 3.21 1.28.76.78 1.2 1.82 1.2 2.97 0 .64-.1 1.27-.33 1.86z" fill="#c4b5fd"/>
                </svg>
              ) : item.icon === 'capcut' ? (
                <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="4" width="20" height="16" rx="3" stroke="#c4b5fd" stroke-width="1.5"/>
                  <polygon points="10,8.5 16,12 10,15.5" fill="#c4b5fd"/>
                  <line x1="2" y1="18" x2="22" y2="18" stroke="#c4b5fd" stroke-width="1.5"/>
                  <rect x="5" y="19" width="3" height="1.5" rx="0.5" fill="#c4b5fd"/>
                  <rect x="9.5" y="19" width="5" height="1.5" rx="0.5" fill="#c4b5fd"/>
                  <rect x="16" y="19" width="3" height="1.5" rx="0.5" fill="#c4b5fd"/>
                </svg>
              ) : (
                <span>{item.icon}</span>
              )}
            </div>
            <h3 class="text-violet-100 font-semibold text-sm">{item.name}</h3>
            <span class="text-xs text-text-muted mt-1 block capitalize">{item.type}</span>
          </div>
        ))}
      </div>

      <button
        class="equip-next absolute right-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-bg-card/80 backdrop-blur border border-deep-violet rounded-full flex items-center justify-center text-violet-300 hover:bg-violet-600 hover:text-white transition-all opacity-0 group-hover:opacity-100 hidden"
        aria-label="Next"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.equip-title', {
    y: 30, duration: 0.8,
    scrollTrigger: { trigger: '#equipment', start: 'top 80%' },
  });

  document.querySelectorAll('.equip-card').forEach((card, i) => {
    gsap.from(card, {
      x: 40, scale: 0.9, duration: 0.5, delay: i * 0.08, ease: 'back.out(1.4)',
      scrollTrigger: { trigger: '#equipment', start: 'top 70%' },
    });
  });

  const track = document.querySelector('.equip-track') as HTMLElement;
  const prevBtn = document.querySelector('.equip-prev') as HTMLElement;
  const nextBtn = document.querySelector('.equip-next') as HTMLElement;

  if (track && prevBtn && nextBtn) {
    const scrollAmount = 240;
    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });

    function updateEquipArrows() {
      const hasOverflow = track.scrollWidth > track.clientWidth + 1;
      const atStart = track.scrollLeft <= 1;
      const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;

      prevBtn.classList.toggle('md:flex', hasOverflow && !atStart);
      nextBtn.classList.toggle('md:flex', hasOverflow && !atEnd);
    }

    track.addEventListener('scroll', updateEquipArrows);
    window.addEventListener('resize', updateEquipArrows);
    updateEquipArrows();
  }
</script>
