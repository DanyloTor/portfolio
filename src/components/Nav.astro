---
const links = [
  { label: 'Про нас', href: '#about' },
  { label: 'Послуги', href: '#services' },
  { label: 'Проєкти', href: '#cases' },
  { label: 'Результати', href: '#results' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 -translate-y-full">
  <div class="backdrop-blur-xl bg-bg-deep/70 border-b border-deep-violet/50">
    <div class="max-w-6xl mx-auto px-4 md:px-8 flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="#hero" class="font-display text-lg font-bold text-text-primary tracking-tight">
        <span class="text-violet-300">E</span>&<span class="text-accent">V</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-text-muted hover:text-violet-300 transition-colors duration-300 tracking-wide"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a
        href="https://ig.me/m/crushikme"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 bg-violet-600/20 hover:bg-violet-600 text-violet-300 hover:text-white text-sm font-medium py-2 px-5 rounded-full border border-violet-600/40 hover:border-violet-600 transition-all duration-300"
      >
        Написати нам
      </a>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden text-violet-300 p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-deep-violet/50">
      <div class="px-4 py-6 flex flex-col gap-4">
        {links.map((link) => (
          <a
            href={link.href}
            class="mobile-link text-text-muted hover:text-violet-300 transition-colors duration-300 text-lg"
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://ig.me/m/crushikme"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex items-center justify-center gap-2 bg-violet-600 text-white font-medium py-3 px-6 rounded-full text-sm"
        >
          Написати в Instagram
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = menuBtn?.querySelector('.menu-open');
  const menuClose = menuBtn?.querySelector('.menu-close');

  // Show nav after scrolling past hero
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const heroHeight = window.innerHeight * 0.6;

    if (nav) {
      if (scrollY > heroHeight) {
        nav.classList.remove('-translate-y-full');
        nav.classList.add('translate-y-0');
      } else {
        nav.classList.add('-translate-y-full');
        nav.classList.remove('translate-y-0');
        // Close mobile menu when scrolling back to top
        mobileMenu?.classList.add('hidden');
        menuOpen?.classList.remove('hidden');
        menuClose?.classList.add('hidden');
      }
    }
    lastScroll = scrollY;
  });

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuOpen?.classList.toggle('hidden');
    menuClose?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuOpen?.classList.remove('hidden');
      menuClose?.classList.add('hidden');
    });
  });
</script>
